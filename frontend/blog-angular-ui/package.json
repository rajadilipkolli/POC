{
  "name": "blog-angular-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "clean": "rimraf ./dist",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "test": "ng test --watch=false --browsers=ChromeHeadlessCustom",
    "test:ci": "cross-env SKIP_BROWSER_TESTS=true ng test --watch=false --browsers=ChromeHeadlessCustom --karma-config=karma.conf.js || (echo 'Tests failed' && exit 1)",
    "test:watch": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "build:ci": "npm run clean && npm run test:ci && npm run build:prod"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.1",
    "@angular/common": "22.0.1",
    "@angular/compiler": "22.0.1",
    "@angular/core": "22.0.1",
    "@angular/forms": "22.0.1",
    "@angular/localize": "22.0.1",
    "@angular/platform-browser": "22.0.1",
    "@angular/platform-browser-dynamic": "22.0.1",
    "@angular/router": "22.0.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.1",
    "@angular/cli": "22.0.1",
    "@angular/compiler-cli": "22.0.1",
    "@angular/language-service": "22.0.1",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "6.0.0",
    "@types/jasminewd2": "2.0.13",
    "@types/node": "24.13.2",
    "angular-eslint": "^22.0.0",
    "cross-env": "^10.0.0",
    "eslint": "10.5.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "6.3.0",
    "jasmine-spec-reporter": "7.0.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "protractor": "7.0.0",
    "puppeteer": "25.1.0",
    "rimraf": "6.1.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
